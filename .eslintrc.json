{
  "root": true,
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars": ["warn"],
    "no-undef": "error",
    "@next/next/no-html-link-for-pages": "off"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module",
    "ecmaFeatures": {"jsx": true}
  }
}
