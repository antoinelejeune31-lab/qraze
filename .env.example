# Vercel Postgres — créer via Vercel Dashboard > Storage > Create Database
# Ces variables sont automatiquement injectées par Vercel après création
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Resend (emails transactionnels) — https://resend.com/api-keys
RESEND_API_KEY=re_...

# Application
NEXT_PUBLIC_APP_NAME=BARNA'B QR
NEXT_PUBLIC_APP_URL=https://votre-domaine.vercel.app

# Mot de passe du dashboard admin (/admin)
ADMIN_PASSWORD=changez-moi

# Secret pour le cron Vercel
CRON_SECRET=changez-moi
