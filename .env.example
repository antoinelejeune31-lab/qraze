# Exemple de variables d'environnement pour le projet

# Supabase (public et clé service role pour les API server-side)
NEXT_PUBLIC_SUPABASE_URL=https://xyzcompany.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key

# Resend (service d'envoi d'emails)
# Obtenez la clé depuis https://resend.com
RESEND_API_KEY=rsnd_live_...

# Application
NEXT_PUBLIC_APP_NAME=QRCraft
# Si vous lancez localement utilisez http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret pour /api/cron/expire-qr
CRON_SECRET=some-secret-value

# Google AdSense (optionnel)
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
